# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (optional — not required for the current demo; leave unset until payments launch)
STRIPE_SECRET_KEY=rk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_CITES_100=price_...
STRIPE_PRICE_CITES_200=price_...
STRIPE_PRICE_CITES_400=price_...
STRIPE_PRICE_CITES_1000=price_...

# Vercel AI Gateway — DeepSeek V4 Flash + OpenAI embeddings
AI_GATEWAY_API_KEY=
# On Vercel deployments, OIDC is used automatically when AI_GATEWAY_API_KEY is unset
# VERCEL_OIDC_TOKEN=

# App URL (OAuth + Stripe redirects). Use http://localhost:3000 for local dev; production: https://pergamum.io
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: secret 6-letter codes — redeem on Cites or Leaderboard to switch plan (dev / admin)
# PGMUP1 is always available: full monthly Pro (subscription row + 300 Cites allotment)
SECRET_PLAN_PRO_CODE=
SECRET_PLAN_BASIC_CODE=

# Research: source discovery + enrichment
# Academic layer (OpenAlex — no API key; mailto identifies your app for the polite pool)
# OpenAlex polite pool identity (email). Optional paid key unlocks search.semantic.
OPENALEX_MAILTO=thestrangecupboard@gmail.com
# OPENALEX_API_KEY=
# Same email is used for Crossref polite pool + Unpaywall (or set UNPAYWALL_EMAIL separately)
UNPAYWALL_EMAIL=thestrangecupboard@gmail.com
# Optional: raises PubMed E-utilities rate limits (Medical Database)
NCBI_API_KEY=
# Required for Legal Database Search (US case law via CourtListener)
COURTLISTENER_API_TOKEN=
# Web discovery
EXA_API_KEY=
# Agentic web search (Perplexity Search API — POST /search, $0.005/request)
PERPLEXITY_API_KEY=
