# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Lemon Squeezy (optional — leave unset until payments launch)
# Dashboard: https://app.lemonsqueezy.com — create store, products/variants, webhook
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_VARIANT_PRO_MONTHLY=
LEMONSQUEEZY_VARIANT_PRO_ANNUAL=
LEMONSQUEEZY_VARIANT_CITES_100=
LEMONSQUEEZY_VARIANT_CITES_200=
LEMONSQUEEZY_VARIANT_CITES_400=
LEMONSQUEEZY_VARIANT_CITES_1000=

# Vercel AI Gateway — DeepSeek V4 Flash + OpenAI embeddings
AI_GATEWAY_API_KEY=
# On Vercel deployments, OIDC is used automatically when AI_GATEWAY_API_KEY is unset
# VERCEL_OIDC_TOKEN=

# App URL (OAuth + Lemon Squeezy checkout redirects). Use http://localhost:3000 for local dev; production: https://pergamum.io
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: secret codes — redeem on Cites or Leaderboard
# PGMUP1: full monthly Pro (subscription row + 200 Cites allotment)
# TRYPGM: demo testers — +250 Cites and a one-month Pro trial (no charge)
SECRET_PLAN_PRO_CODE=
SECRET_PLAN_BASIC_CODE=
# Optional alias for TRYPGM (same bundle)
DEMO_TESTER_CODE=

# Research: source discovery + enrichment
# Academic layer (OpenAlex — no API key; mailto identifies your app for the polite pool)
# OpenAlex polite pool identity (email). Optional paid key unlocks search.semantic.
OPENALEX_MAILTO=thestrangecupboard@gmail.com
# OPENALEX_API_KEY=
# Same email is used for Crossref polite pool + Unpaywall (or set UNPAYWALL_EMAIL separately)
UNPAYWALL_EMAIL=thestrangecupboard@gmail.com
# Optional: raises PubMed E-utilities rate limits (Medical Database)
NCBI_API_KEY=
# Required for Legal Database Search (US case law via CourtListener)
COURTLISTENER_API_TOKEN=
# Web discovery
EXA_API_KEY=
# Agentic web search (Perplexity Search API — POST /search, $0.005/request)
PERPLEXITY_API_KEY=
# Optional: LlamaCloud PDF fallback when Exa leaves authors/dates thin on .pdf URLs
# Get a key at https://cloud.llamaindex.ai — uses LlamaParse + LlamaExtract (cost_effective)
LLAMA_CLOUD_API_KEY=
# Optional: pin to a LlamaCloud project (otherwise the API key default / job project is used)
# LLAMA_CLOUD_PROJECT_ID=
